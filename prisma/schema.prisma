generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String                @id @default(uuid())
  email                  String                @unique
  username               String?               @unique
  fullName               String?
  avatarUrl              String?
  role                   String                @default("shopper")
  password               String                @default("")
  bio                    String?
  niche                  String?
  websiteUrl             String?
  instagramUrl           String?
  tiktokUrl              String?
  youtubeUrl             String?
  dolapAccountUrl        String?
  gardropsAccountUrl     String?
  shopierAccountUrl      String?
  location               String?
  phoneNumber            String?               @unique
  isVerified             Boolean               @default(false)
  phoneCode              String?
  phoneCodeExpires       DateTime?
  applicationStatus      String                @default("approved")
  rejectionReason        String?
  dateOfBirth            DateTime?
  gender                 String?
  ethnicity              String?
  giftPreferences        String?
  identity               String?
  openToPromote          String?
  familyStatus           String?
  lifeEvents             String?
  instagramFollowerCount Int                   @default(0)
  audienceData           String?
  themeConfig            String?
  xp                     Int                   @default(0)
  followersCount         Int                   @default(0)
  productsSharedCount    Int                   @default(0)
  profileViewCount       Int                   @default(0)
  totalEarnings          Decimal               @default(0.00)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  feedbacks              Feedback[]
  adClicks               AdClick[]
  campaignApplications   CampaignApplication[]
  circleMemberships      CircleMember[]
  createdCircles         Circle[]              @relation("CircleCreator")
  collections            Collection[]
  magazines              Magazine[]
  favorites              Favorite[]
  payments               Payment[]
  payouts                Payout[]
  socialAccounts         SocialAccount[]
  taxInfo                TaxInfo?
  transactions           Transaction[]
  userQuests             UserQuest[]

  @@map("users")
}

model SocialAccount {
  id             String    @id @default(uuid())
  userId         String
  platform       String
  platformUserId String?
  username       String?
  followerCount  Int?
  accessToken    String?
  refreshToken   String?
  lastSyncedAt   DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("social_accounts")
}

model Brand {
  id                 String     @id @default(uuid())
  name               String
  slug               String     @unique
  logoUrl            String?
  websiteUrl         String?
  description        String?
  integrationType    String     @default("manual")
  externalPlatformId String?
  commissionRate     Decimal    @default(10.00)
  contactName        String?
  contactTitle       String?
  contactEmail       String?
  contactPhone       String?
  estimatedBudget    String?
  mainGoal           String?
  taxId              String?
  status             String     @default("pending")
  createdAt          DateTime   @default(now())
  campaigns          Campaign[]
  products           Product[]

  @@map("brands")
}

model Product {
  id                   String           @id @default(uuid())
  brandId              String?
  title                String
  description          String?
  price                Decimal?
  currency             String           @default("TRY")
  salePrice            Decimal?
  externalId           String?
  sku                  String?
  stockStatus          String           @default("in_stock")
  productUrl           String
  affiliateUrlTemplate String?
  imageUrl             String?
  category             String?
  clickCount           Int              @default(0)
  viewCount            Int              @default(0)
  favoritesCount       Int              @default(0)
  createdAt            DateTime         @default(now())
  indexedAt            DateTime         @default(now())
  collectionItems      CollectionItem[]
  magazinePages        MagazinePage[]
  favorites            Favorite[]
  brand                Brand?           @relation(fields: [brandId], references: [id])

  @@map("products")
}

model Collection {
  id            String           @id @default(uuid())
  userId        String
  title         String
  slug          String?
  description   String?
  coverImageUrl String?
  isPublic      Boolean          @default(true)
  layoutType    String           @default("grid")
  category      String?
  displayOrder  Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @default(now()) @updatedAt
  items         CollectionItem[]
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("collections")
}

model CollectionItem {
  id             String     @id @default(uuid())
  collectionId   String
  productId      String
  curatorComment String?
  customTitle    String?
  customImageUrl String?
  displayOrder   Int        @default(0)
  clickCount     Int        @default(0)
  isVisible      Boolean    @default(true)
  createdAt      DateTime   @default(now())
  collection     Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product        Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("collection_items")
}

model Circle {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  description   String?
  coverImageUrl String?
  creatorId     String?
  isVerified    Boolean        @default(true)
  type          String         @default("public")
  status        String         @default("approved")
  createdAt     DateTime       @default(now())
  members       CircleMember[]
  creator       User?          @relation("CircleCreator", fields: [creatorId], references: [id])

  @@map("circles")
}

model CircleMember {
  circleId String
  userId   String
  role     String   @default("member")
  status   String   @default("approved")
  joinedAt DateTime @default(now())
  circle   Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([circleId, userId])
  @@map("circle_members")
}

model AnalyticsEvent {
  id         String   @id @default(uuid())
  type       String
  entityId   String
  entityType String
  userId     String?
  sessionId  String?
  metadata   String?
  createdAt  DateTime @default(now())

  @@index([entityId, entityType])
  @@index([type])
  @@map("analytics_events")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("favorites")
}

model Payment {
  id         String   @id @default(uuid())
  userId     String
  amount     Decimal
  currency   String   @default("TRY")
  status     String   @default("pending")
  provider   String   @default("iyzico")
  type       String
  targetId   String?
  externalId String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@map("payments")
}

model Transaction {
  id          String    @id @default(uuid())
  userId      String
  type        String
  amount      Decimal
  currency    String    @default("TRY")
  status      String    @default("PENDING")
  sourceType  String?
  sourceId    String?
  description String?
  toBePaidAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@map("transactions")
}

model Payout {
  id          String    @id @default(uuid())
  userId      String
  amount      Decimal
  status      String    @default("PROCESSING")
  iban        String
  receiptUrl  String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])

  @@map("payouts")
}

model TaxInfo {
  id        String   @id @default(uuid())
  userId    String   @unique
  fullName  String
  idNumber  String
  address   String
  isCompany Boolean  @default(false)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@map("tax_info")
}

model Campaign {
  id           String                @id @default(uuid())
  brandId      String
  title        String
  description  String
  requirements String?
  budget       Decimal?
  currency     String                @default("TRY")
  type         String                @default("gifting")
  status       String                @default("active")
  createdAt    DateTime              @default(now())
  expiresAt    DateTime?
  applications CampaignApplication[]
  brand        Brand                 @relation(fields: [brandId], references: [id])

  @@map("campaigns")
}

model CampaignApplication {
  id           String   @id @default(uuid())
  campaignId   String
  userId       String
  pitch        String?
  budget       Decimal?
  currency     String   @default("TRY")
  includeStats Boolean  @default(true)
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
  @@map("campaign_applications")
}

model DailyAnalytics {
  id               String   @id @default(uuid())
  userId           String?
  date             DateTime @default(dbgenerated("CURRENT_DATE"))
  views            Int      @default(0)
  clicks           Int      @default(0)
  instagramClicks  Int      @default(0)
  tiktokClicks     Int      @default(0)
  directClicks     Int      @default(0)
  ordersGenerated  Int      @default(0)
  estimatedRevenue Decimal  @default(0)

  @@unique([userId, date])
  @@map("daily_analytics")
}

model Quest {
  id          String      @id @default(uuid())
  title       String
  description String
  points      Int         @default(10)
  actionUrl   String?
  type        String
  createdAt   DateTime    @default(now())
  userQuests  UserQuest[]

  @@map("quests")
}

model UserQuest {
  id          String    @id @default(uuid())
  userId      String
  questId     String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questId])
  @@map("user_quests")
}

model Feedback {
  id        String   @id @default(uuid())
  content   String
  type      String   @default("suggestion")
  url       String?
  userId    String?
  createdAt DateTime @default(now())
  status    String   @default("new")
  user      User?    @relation(fields: [userId], references: [id])
}

model AdCampaign {
  id          String    @id @default(uuid())
  title       String
  brandName   String
  description String?
  imageUrl    String
  targetUrl   String
  targetType  String    @default("native")
  startDate   DateTime  @default(now())
  endDate     DateTime
  isActive    Boolean   @default(true)
  budget      Decimal   @default(0.00)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  clicks      AdClick[]

  @@map("ad_campaigns")
}

model AdClick {
  id           String     @id @default(uuid())
  adCampaignId String
  userId       String?
  ipAddress    String?
  userAgent    String?
  clickedAt    DateTime   @default(now())
  campaign     AdCampaign @relation(fields: [adCampaignId], references: [id], onDelete: Cascade)
  user         User?      @relation(fields: [userId], references: [id])

  @@index([adCampaignId])
  @@map("ad_clicks")
}

model Magazine {
  id            String         @id @default(uuid())
  userId        String
  title         String
  description   String?
  coverImageUrl String?
  themeId       String?        @default("default")
  isPublic      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  pages         MagazinePage[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("magazines")
}

model MagazinePage {
  id           String   @id @default(uuid())
  magazineId   String
  productId    String?
  pageType     String   @default("product") // 'cover', 'product', 'text', 'image'
  content      String?  @db.Text
  imageUrl     String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  magazine     Magazine @relation(fields: [magazineId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("magazine_pages")
}
